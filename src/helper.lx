@module "helper"

@use "std_libc" as libc

const RAND_MAX: double = 2147483647.0;

pub const sigmoid -> fn (x: double) double {
    if (x > 500.0)  return 1.0;
    if (x < -500.0) return 0.0;
    return 1.0 / (1.0 + libc::exp(-x));
}

pub const random_double -> fn (min: double, max: double) double {
    return (cast<double>(libc::rand()) / RAND_MAX) * (max - min) + min;
}